# ==========================================
# Configurações do Banco de Dados (MySQL)
# ==========================================
# Host local geralmente é 127.0.0.1 (evite usar 'localhost' por causa do IPv6 no Node)
DB_HOST=127.0.0.1
DB_PORT=3306

# Credenciais do banco (Mude a senha para a sua senha local do MySQL)
DB_USER=root
DB_PASSWORD=sua_senha_local_aqui
DB_NAME=healthhub_dev